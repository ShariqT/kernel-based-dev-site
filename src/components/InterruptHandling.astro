---
const nodes = [
  { label: "Hardware Interrupt", tone: "amber" },
  { label: "ISR", tone: "cyan" },
  { label: "Kernel", tone: "indigo" },
];
---

<section class="card interrupt" id="scheduling">
  <h3 class="card-title">Interrupt Handling</h3>
  <div class="int-flow">
    {
      nodes.map((node, i) => (
        <>
          <span class:list={["int-node", node.tone]}>{node.label}</span>
          {i < nodes.length - 1 && (
            <svg class="int-arrow" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14 M13 6l6 6-6 6" />
            </svg>
          )}
        </>
      ))
    }
  </div>
  <p class="int-note">Animation · IRQ → vector dispatch → handler</p>
</section>

<style>
  .interrupt {
    padding: 18px;
  }

  .int-flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 18px;
    flex-wrap: wrap;
  }

  .int-node {
    font-size: 0.74rem;
    font-weight: 600;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .int-node.amber {
    color: #fbbf24;
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
  }

  .int-node.cyan {
    color: var(--accent-cyan);
    background: rgba(45, 212, 191, 0.1);
    border: 1px solid rgba(45, 212, 191, 0.3);
  }

  .int-node.indigo {
    color: #a5b4fc;
    background: rgba(99, 102, 241, 0.12);
    border: 1px solid rgba(99, 102, 241, 0.35);
  }

  .int-arrow {
    color: var(--text-muted);
    animation: nudge 1.6s ease-in-out infinite;
  }

  @keyframes nudge {
    0%, 100% {
      transform: translateX(0);
      opacity: 0.5;
    }
    50% {
      transform: translateX(3px);
      opacity: 1;
    }
  }

  .int-note {
    text-align: center;
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-top: 16px;
  }
</style>

---
const navItems = [
  { label: "Overview", href: "/", active: false },
  { label: "Learn", href: "/proc4", active: false },
  { label: "Engineering Deep Dive", href: "/docs", active: false }
];
const { pathname } = Astro.url; 
for (const val of navItems){
  if (pathname === val.href) {
    val.active = true
  }
}

---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="#top">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="28" height="28">
          <defs>
            <linearGradient id="brandG" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#38bdf8" />
              <stop offset="0.55" stop-color="#6366f1" />
              <stop offset="1" stop-color="#a855f7" />
            </linearGradient>
          </defs>
          <path
            fill="url(#brandG)"
            d="M16 2 4 9v14l12 7 12-7V9L16 2Zm0 3.3 8.6 5L16 15.3 7.4 10.3 16 5.3Zm-9 7.1 8 4.6v9.1l-8-4.6v-9.1Zm10 13.7v-9.1l8-4.6v9.1l-8 4.6Z"
          ></path>
          <circle cx="16" cy="16" r="2.4" fill="#fff" opacity="0.9"></circle>
        </svg>
      </span>
      <span class="brand-name">Kernel Development</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        navItems.map((item) => (
          <a class:list={["nav-link", { active: item.active }]} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <a class="gh-link" href="https://github.com" aria-label="GitHub repository">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
        <path
          d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.8 18.3 5.1 18.3 5.1c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
        ></path>
      </svg>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(6, 9, 18, 0.72);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border-soft);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    height: 64px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    filter: drop-shadow(0 0 10px rgba(99, 102, 241, 0.35));
  }

  .brand-name {
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
  }

  .nav-link {
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    transition: color 0.18s ease, background 0.18s ease;
  }

  .nav-link:hover {
    color: var(--text-secondary);
    background: rgba(118, 146, 198, 0.06);
  }

  .nav-link.active {
    color: var(--text-primary);
    background: rgba(99, 102, 241, 0.12);
    box-shadow: inset 0 0 0 1px rgba(99, 102, 241, 0.3);
  }

  .gh-link {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: color 0.18s ease, background 0.18s ease;
  }

  .gh-link:hover {
    color: var(--text-primary);
    background: rgba(118, 146, 198, 0.08);
  }

  @media (max-width: 900px) {
    .nav {
      display: none;
    }
  }
</style>

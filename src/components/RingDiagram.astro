---
const ring0Traits = [
  "Full Hardware Access",
  "Privileged Instructions Allowed",
  "Trusted Code (OS Kernel)",
  "Most Privileged",
];
---

<div class="ring-outer">
  <span class="apps-icons" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 3H7a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V7Z" />
      <path d="M14 3v4h4 M9 12h6 M9 15h6 M9 9h2" />
    </svg>
    <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3" />
      <path d="M12 2v3 M12 19v3 M2 12h3 M19 12h3 M5 5l2 2 M17 17l2 2 M19 5l-2 2 M7 17l-2 2" />
    </svg>
  </span>

  <div class="ring-inner">
    <span class="kernel-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="8.5" />
        <path d="M12 3.5v2.5 M12 18v2.5 M3.5 12H6 M18 12h2.5 M6 6l1.8 1.8 M16.2 16.2 18 18 M18 6l-1.8 1.8 M7.8 16.2 6 18" />
        <text x="12" y="14.6" text-anchor="middle" font-size="7.5" font-weight="700" fill="currentColor" stroke="none">K</text>
      </svg>
    </span>
    <h4 class="ring0-title">Ring 0: Kernel Mode</h4>
    <ul class="ring0-list">
      {ring0Traits.map((t) => <li>{t}</li>)}
    </ul>
  </div>
</div>

<style>
  .ring-outer {
    --ring-green: #4ade80;
    --ring-cyan: #38bdf8;
    position: relative;
    width: min(420px, 100%);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 2.5px solid var(--ring-cyan);
    display: grid;
    place-items: center;
    background: radial-gradient(
      circle at 50% 42%,
      rgba(56, 189, 248, 0.1),
      rgba(6, 9, 18, 0.25) 72%
    );
    box-shadow: 0 0 44px -8px rgba(56, 189, 248, 0.55),
      inset 0 0 44px -14px rgba(56, 189, 248, 0.45);
  }

  .apps-icons {
    position: absolute;
    top: 7%;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 14px;
    color: var(--text-secondary);
  }

  .ring-inner {
    width: 67%;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 2.5px solid var(--ring-green);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 20px;
    background: radial-gradient(
      circle at 50% 45%,
      rgba(13, 28, 24, 0.95),
      rgba(6, 12, 14, 0.96)
    );
    box-shadow: 0 0 38px -8px rgba(74, 222, 128, 0.55),
      inset 0 0 30px -10px rgba(74, 222, 128, 0.4);
  }

  .kernel-icon {
    color: var(--ring-green);
    filter: drop-shadow(0 0 12px rgba(74, 222, 128, 0.55));
    margin-bottom: 8px;
  }

  .ring0-title {
    font-size: 0.94rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--ring-green);
    margin-bottom: 8px;
  }

  .ring0-list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.72rem;
    line-height: 1.65;
    color: var(--text-primary);
  }

  @media (max-width: 440px) {
    .ring-inner {
      padding: 0 12px;
    }

    .ring0-list {
      font-size: 0.66rem;
    }
  }
</style>

<section class="hero" id="architecture">
  <p class="hero-eyebrow mono">// kernel.architecture.inspect()</p>
  <h1 class="hero-title">
    <span class="gradient-text">Kernel-based Development:</span>
    <span class="hero-title-rest">Extending your System's Core</span>
  </h1>
</section>

<style>
  .hero {
    text-align: center;
    padding: 56px 0 36px;
  }

  .hero-eyebrow {
    font-size: 0.78rem;
    color: var(--accent-cyan);
    letter-spacing: 0.04em;
    margin-bottom: 16px;
    opacity: 0.85;
  }

  .hero-title {
    font-size: clamp(1.9rem, 4.6vw, 3.2rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    max-width: 980px;
    margin: 0 auto;
  }

  .gradient-text {
    filter: drop-shadow(0 0 24px rgba(99, 102, 241, 0.25));
  }

  .hero-title-rest {
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 36px 0 24px;
    }
  }
</style>

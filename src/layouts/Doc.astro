---
import "../styles/semantic.min.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kernel Development - Engineering Docs",
  description = "Unveiling the operating system's core — an interactive guide to kernel architecture, scheduling, memory and I/O.",
} = Astro.props;

const menuItems = [
  {label: 'Engineerig Overview', active: false, href: '/docs'},
  {label: 'Helpful Tips', active: false, href: '/docs-things'},
  {label: 'Testing', active: false, href: '/docs-testing'}

]

const { pathname } = Astro.url; 
for (const val of menuItems){
  if (pathname === val.href) {
    val.active = true
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="ui large stackable inverted menu">
    <div class="ui container">
      <div class="header item">Kernel Engineering Docs</div>
      {
        menuItems.map((item) => (
          <a class:list={["item", { active: item.active }]} href={item.href}>
            {item.label}
          </a>
        ))
      }
      
      <div class="right menu">
        <a class="item" href="/">Kernel Development</a>
      </div>
    </div>
  </div>
    <slot />
  </body>
</html>

<style>
  .doc-main {
    margin-top: 2.5rem;
    margin-bottom: 4rem;
  }

  .doc-nav {
    position: sticky;
    top: 1.5rem;
  }

  .ui.dividing.header {
    scroll-margin-top: 1.5rem;
    margin-top: 2.5rem;
  }

  .folder-tree {
    margin: 0;
    font-size: 0.82em;
    line-height: 1.55;
    overflow-x: auto;
  }
</style>
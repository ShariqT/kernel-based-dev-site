---
import DocHeader from "../components/DocHeader.astro";
import "../styles/semantic.min.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kernel Development - Engineering Docs",
  description = "Unveiling the operating system's core — an interactive guide to kernel architecture, scheduling, memory and I/O.",
} = Astro.props;




---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  .doc-main {
    margin-top: 2.5rem;
    margin-bottom: 4rem;
  }

  .doc-nav {
    position: sticky;
    top: 1.5rem;
  }

  .ui.dividing.header {
    scroll-margin-top: 1.5rem;
    margin-top: 2.5rem;
  }

  .folder-tree {
    margin: 0;
    font-size: 0.82em;
    line-height: 1.55;
    overflow-x: auto;
  }
</style>